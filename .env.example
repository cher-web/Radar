# Pick your vision provider. Defaults to "claude" if unset.
# Valid: claude | gemini
RADAR_VISION_PROVIDER=claude

# Anthropic (Claude) — used when RADAR_VISION_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# Google (Gemini) — used when RADAR_VISION_PROVIDER=gemini
GOOGLE_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

# --- Optional: auto-publish to a public calendar after each scan ---
# If these are set, `radar scan` uploads upcoming events + screenshots to your
# own Cloudflare R2 bucket. Pair with the radar-calendar viewer:
# https://github.com/<your-fork>/radar-calendar
# Leave unset to disable publishing entirely (scans still work normally).
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
